# Mission Control — variáveis de ambiente
# ----------------------------------------
# COPIE este arquivo pra .env (que está no .gitignore) e preencha os valores reais.
# Nunca comite .env no git.

# Supabase — pegue em https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://seu-projeto.supabase.co

# Anon key pra uso no browser (painel Vercel)
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Service role key SOMENTE pra scripts server-side (imports, migrações).
# NÃO usar no browser. Tem acesso total ao banco, bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz

# Opcional — quando V1 ligar
# DISCORD_WEBHOOK_SECRET=
# WHATSAPP_API_TOKEN=
# OPENAI_API_KEY=
